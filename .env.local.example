# Exaroton API — get your token at https://exaroton.com/account/
# When set, server status is fetched directly from Exaroton (more reliable)
# Without this, falls back to api.mcsrvstat.us
EXAROTON_API_KEY=

# Optional: your server ID (avoids an extra API lookup on every request)
# Find it in the URL when viewing your server on exaroton.com
EXAROTON_SERVER_ID=
