# Exaroton API — get your token at https://exaroton.com/account/
# When set, server status is fetched directly from Exaroton (more reliable)
# Without this, falls back to api.mcsrvstat.us
EXAROTON_API_KEY=

# The hostname of your Exaroton server (e.g. yourname.exaroton.me)
# Defaults to stebbias.exaroton.me if not set
EXAROTON_SERVER_HOST=

# Optional: your server ID (avoids an extra API lookup on every request)
# Find it in the URL when viewing your server on exaroton.com
EXAROTON_SERVER_ID=

# Admin panel password — set to any secret string (min 8 chars), used to log in to /admin
ADMIN_TOKEN=

# GitHub token (optional) — increases rate limit for datapack update checks from 60 to 5000 req/hr
# Create at https://github.com/settings/tokens (classic, no scopes needed for public repos)
GITHUB_TOKEN=

# Crew member tokens — one per player, used for crew profile login
# Format: CREW_TOKEN_<UPPERCASE_USERNAME>=<secret>
CREW_TOKEN_STEBBIAS=
CREW_TOKEN_AMMAGAUR=
CREW_TOKEN_JOENANA=
CREW_TOKEN_INGUNNBIRTA=
CREW_TOKEN_GAMLA123=
CREW_TOKEN_FAFNIR1994=
CREW_TOKEN_IMLONELY=
CREW_TOKEN_EIKIBLEIKI=

# ─── Vercel Storage (required for production) ─────────────────────────────────
# Redis — stores crew profiles, posts, gallery metadata, and stat snapshots
# Add via: Vercel Dashboard → Storage → Create Redis Database
# The REDIS_URL is shown in the database dashboard and auto-added when connected
REDIS_URL=

# Vercel Blob — stores uploaded photos (gallery + crew)
# Add via: Vercel Dashboard → Storage → Create Blob Store
BLOB_READ_WRITE_TOKEN=
