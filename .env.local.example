# Exaroton API — get your token at https://exaroton.com/account/
# When set, server status is fetched directly from Exaroton (more reliable)
# Without this, falls back to api.mcsrvstat.us
EXAROTON_API_KEY=

# Optional: your server ID (avoids an extra API lookup on every request)
# Find it in the URL when viewing your server on exaroton.com
EXAROTON_SERVER_ID=

# Admin panel password — set to any secret string, used to log in to /admin
ADMIN_TOKEN=

# GitHub token (optional) — increases rate limit for datapack update checks from 60 to 5000 req/hr
# Create at https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=

# Crew member tokens — one per player, used for crew profile login
# Format: CREW_TOKEN_<UPPERCASE_USERNAME>=<secret>
# Example:
CREW_TOKEN_STEBBIAS=
CREW_TOKEN_JONGODI=
# Add one line per crew member
